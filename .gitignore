# KG Gitignore

# Codebase memory database (large binary)
**/codebase.db
**/codebase.db-*

# Cloned repos (too large, fetched on demand)
projects/*/repo/

# Agent transcripts
.claude/transcripts/

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc

# Backup files
*.bak

# Cloned repos (per org)
projects/*/*/repo/
# MCP cache (large binary, not pushed)
.cbm-cache/
